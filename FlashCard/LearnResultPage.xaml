<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FlashCard.LearnResultPage"
             Title="Résultats">

    <VerticalStackLayout Padding="30" Spacing="30" VerticalOptions="Center">
        <Label Text="Session Terminée !" 
               FontSize="32" 
               FontAttributes="Bold" 
               HorizontalOptions="Center" />
        
        <Label x:Name="DeckNameLabel" 
               Text="Nom du Deck" 
               FontSize="18" 
               TextColor="Gray" 
               HorizontalOptions="Center" />

        <Frame BackgroundColor="#F0F0F0" Padding="30" CornerRadius="20">
            <VerticalStackLayout Spacing="10">
                <Label x:Name="ScoreLabel" 
                       Text="8 / 10" 
                       FontSize="48" 
                       FontAttributes="Bold" 
                       HorizontalOptions="Center" />
                <Label x:Name="PercentageLabel" 
                       Text="80%" 
                       FontSize="24" 
                       TextColor="#4CAF50" 
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Frame>

        <Button Text="Retour à l'accueil" 
                Clicked="OnHomeClicked" 
                BackgroundColor="#2196F3" 
                TextColor="White" 
                Padding="15" />
    </VerticalStackLayout>
</ContentPage>