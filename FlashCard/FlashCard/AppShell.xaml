<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FlashCard.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:FlashCard"
    Shell.FlyoutBehavior="Disabled"
    Title="FlashCard">

    
    <TabBar>
        <Tab Title="Home">
            <ShellContent Title="Home" ContentTemplate="{DataTemplate local:MainPage}" Route="MainPage" />
        </Tab>
        <Tab Title="Layout">
            <ShellContent Title="Layout" ContentTemplate="{DataTemplate local:Layout}" Route="Layout" />
        </Tab>
    </TabBar>

</Shell>
